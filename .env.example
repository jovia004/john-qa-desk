# Copy to .env and fill in real values. Never commit .env.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_api_token_here

# Comma-separated project keys shown in the dropdown (e.g. OS, APOS, IPOS)
JIRA_PROJECTS=OS

# Custom field id for Story Points (Atlassian default is customfield_10016;
# check yours at /rest/api/3/field if uploads fail)
JIRA_STORY_POINTS_FIELD=customfield_10016

# Statuses considered "Ready for Testing / Testing" (lowercased, comma-separated)
TESTING_STATUSES=ready for testing,testing,in qa,qa

PORT=1111

# Check Readiness — LLM that validates tickets against rules/readyfortest.md.
# Provider auto-detected from READINESS_MODEL: gpt-*/o* → OpenAI, claude-* → Anthropic.
# Fill in the key for whichever provider you choose. Leave it blank to disable.
READINESS_MODEL=gpt-4o
# Optional: stronger/reasoning model just for Prepare TC (better AC coverage).
# gpt-*/o* → OpenAI, claude-* → Anthropic. Falls back to READINESS_MODEL if blank.
# Reasoning models (o3, o4-mini) are supported and run slower but cover more.
TC_MODEL=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
