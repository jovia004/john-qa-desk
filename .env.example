# Copy to .env and fill in real values. Never commit .env.
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your_api_token_here

# Comma-separated project keys shown in the dropdown
JIRA_PROJECTS=APOS,IPOS,KSK,AKSK,KGO,DLV

# Custom field id for Story Points (Atlassian default is customfield_10016;
# check yours at /rest/api/3/field if uploads fail)
JIRA_STORY_POINTS_FIELD=customfield_10016

# Statuses considered "Ready for Testing / Testing" (lowercased, comma-separated)
TESTING_STATUSES=ready for testing,testing,in qa,qa

PORT=5173
